{
  "name": "keel",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "keel",
      "version": "0.1.0",
      "license": "MIT",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "engines": {
        "node": ">=20"
      }
    },
    "apps/desktop-host": {
      "name": "@keel/desktop-host",
      "version": "0.1.0"
    },
    "apps/node-backend": {
      "name": "@keel/node-backend",
      "version": "0.1.0"
    },
    "node_modules/@keel/desktop-host": {
      "resolved": "apps/desktop-host",
      "link": true
    },
    "node_modules/@keel/host-config": {
      "resolved": "packages/host-config",
      "link": true
    },
    "node_modules/@keel/js-extension-sdk": {
      "resolved": "packages/js-extension-sdk",
      "link": true
    },
    "node_modules/@keel/node-backend": {
      "resolved": "apps/node-backend",
      "link": true
    },
    "node_modules/@keel/protocol": {
      "resolved": "packages/protocol",
      "link": true
    },
    "node_modules/@keel/runtime": {
      "resolved": "packages/runtime",
      "link": true
    },
    "packages/host-config": {
      "name": "@keel/host-config",
      "version": "0.1.0",
      "license": "MIT"
    },
    "packages/js-extension-sdk": {
      "name": "@keel/js-extension-sdk",
      "version": "0.1.0",
      "license": "MIT"
    },
    "packages/protocol": {
      "name": "@keel/protocol",
      "version": "0.1.0",
      "license": "MIT"
    },
    "packages/runtime": {
      "name": "@keel/runtime",
      "version": "0.1.0",
      "license": "MIT"
    }
  }
}
