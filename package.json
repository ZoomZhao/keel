{
  "name": "keel",
  "version": "0.1.0",
  "private": true,
  "description": "An extensible desktop app foundation with Rust-capable extensions.",
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node apps/desktop-host/src/dev.mjs",
    "ui": "node apps/web-frontend/server.mjs",
    "native:macos": "swift run --package-path apps/native-shells/macos KeelMacShell",
    "native:windows": "dotnet run --project apps/native-shells/windows/Keel.WindowsShell.csproj",
    "gen": "node tools/generate-protocol.mjs",
    "check": "node tools/check-workspace.mjs",
    "test": "node --test",
    "test:node": "node --test",
    "test:rust": "cargo test --workspace",
    "backend:demo": "node apps/node-backend/src/main.mjs --extension extensions/js/hello-world"
  },
  "engines": {
    "node": ">=20"
  }
}
